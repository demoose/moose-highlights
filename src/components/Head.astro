---
import { SITE } from '../config';

interface BookMeta {
  title: string;
  author: string;
  png: string;
}

interface Props {
  title?: string;
  book?: BookMeta;
}

const { title, book } = Astro.props;
const pageTitle = title ? `${title} | ${SITE.title}` : SITE.title;
const description = book
  ? `Notes and tweaks from ${book.title} by ${book.author}`
  : SITE.description;
const image = book ? `${SITE.url}${book.png}` : `${SITE.url}/assets/images/share-icon.png`;
const ogUrl = `${SITE.url}${Astro.url.pathname}`;
---
<head>
  <title>{pageTitle}</title>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />

  <link rel="icon" href="/assets/images/favicon.svg" type="image/svg+xml" />
  <link rel="alternate icon" href="/assets/images/favicon-16.png" sizes="16x16" type="image/png" />
  <link rel="alternate icon" href="/assets/images/favicon-32.png" sizes="32x32" type="image/png" />
  <link rel="alternate icon" href="/assets/images/favicon-48.png" sizes="48x48" type="image/png" />
  <link rel="alternate icon" href="/assets/images/favicon-62.png" sizes="62x62" type="image/png" />
  <link rel="alternate icon" href="/assets/images/favicon-192.png" sizes="192x192" type="image/png" />

  <meta name="twitter:card" content="summary" />
  <meta name="twitter:site" content={SITE.twitter} />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image:src" content={image} />
  {book && <meta name="twitter:image:alt" content={`Cover of ${book.title}`} />}

  <meta property="og:url" content={ogUrl} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />

  <link
    rel="preload"
    href="https://fonts.googleapis.com/css?family=Karla|Sorts+Mill+Goudy&display=swap"
    as="style"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript>
    <link href="https://fonts.googleapis.com/css?family=Karla|Sorts+Mill+Goudy&display=swap" rel="stylesheet" />
  </noscript>
  <link rel="stylesheet" href="/assets/css/style.css?v2021.06.17" />
</head>
